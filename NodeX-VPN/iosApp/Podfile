# iosApp/Podfile
# Firebase dependencies for NodeX VPN iOS
# GoogleService-Info.plist is injected via CI GitHub secret - never committed.

platform :ios, '16.0'
use_frameworks!
inhibit_all_warnings!

workspace 'NodeXVPN'

# ── Main App target ──────────────────────────────────────────────────────────
target 'NodeXVPN' do
  # Firebase
  pod 'FirebaseCore',       '~> 11.6'
  pod 'FirebaseAuth',       '~> 11.6'
  pod 'FirebaseAnalytics',  '~> 11.6'

  # Google Sign-In
  pod 'GoogleSignIn',       '~> 8.0'

  # KMP shared framework is linked via Swift Package (Package.swift)
end

# ── Tunnel Extension target ──────────────────────────────────────────────────
target 'NodeXTunnel' do
  # Tunnel extension doesn't need Firebase directly
  # Arti / Rust core is linked as XCFramework
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
    end
  end
end
