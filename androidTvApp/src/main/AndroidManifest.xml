<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.nodex.vpn.androidtv">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- TV hardware declarations -->
    <!-- Touch screen is NOT required on TV -->
    <uses-feature android:name="android.hardware.touchscreen"
        android:required="false" />
    <!-- Declare TV support — required for Google Play TV store listing -->
    <uses-feature android:name="android.software.leanback"
        android:required="false" />

    <application
        android:name=".TvApplication"
        android:label="NodeX VPN"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/tv_banner"
        android:theme="@style/Theme.NodeXVpnTv"
        android:allowBackup="false"
        android:isGame="false">

        <!-- ── TV Main Activity ──────────────────────────────────────────── -->
        <activity
            android:name=".TvMainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|navigation|screenLayout|screenSize">
            <!-- Phone launcher intent — opens on mobile too if installed there -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- TV launcher intent — shows on Android TV home screen -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── VPN Service (shared with phone module) ────────────────────── -->
        <service
            android:name="com.nodex.vpn.android.NodeXVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="VPN tunnel via Tor network" />
        </service>

        <!-- ── Boot receiver ─────────────────────────────────────────────── -->
        <receiver
            android:name="com.nodex.vpn.android.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
