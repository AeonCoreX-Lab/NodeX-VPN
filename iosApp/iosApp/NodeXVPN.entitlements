<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ── Network Extension entitlements ────────────────────────────── -->
    <key>com.apple.developer.networking.networkextension</key>
    <array>
        <string>packet-tunnel-provider</string>
    </array>

    <!-- ── App Groups (share data between app and tunnel extension) ────── -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.nodex.vpn</string>
    </array>

    <!-- ── Keychain access ────────────────────────────────────────────── -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.nodex.vpn</string>
    </array>

    <!-- ── Network access ────────────────────────────────────────────── -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- ── Push notifications (for VPN status updates) ───────────────── -->
    <key>aps-environment</key>
    <string>development</string>
</dict>
</plist>
